{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:admin": "set NEXT_PUBLIC_APP_VARIANT=admin&& next dev -p 3000",
    "dev:driver": "set NEXT_PUBLIC_APP_VARIANT=driver&& next dev -p 3000",
    "dev:customer": "set NEXT_PUBLIC_APP_VARIANT=customer&& next dev -p 3000",
    "dev:phone": "next dev -H 0.0.0.0 -p 3000",
    "dev:https": "next dev -H 0.0.0.0 -p 3000 --experimental-https",
    "dev:https:lan": "next dev -H 0.0.0.0 -p 3000 --experimental-https --experimental-https-key certificates/lan-key.pem --experimental-https-cert certificates/lan-cert.pem",
    "dev:https:admin": "set NEXT_PUBLIC_APP_VARIANT=admin&& next dev -H 0.0.0.0 -p 3000 --experimental-https",
    "dev:https:lan:admin": "set NEXT_PUBLIC_APP_VARIANT=admin&& next dev -H 0.0.0.0 -p 3000 --experimental-https --experimental-https-key certificates/lan-key.pem --experimental-https-cert certificates/lan-cert.pem",
    "dev:https:driver": "set NEXT_PUBLIC_APP_VARIANT=driver&& next dev -H 0.0.0.0 -p 3000 --experimental-https",
    "dev:https:lan:driver": "set NEXT_PUBLIC_APP_VARIANT=driver&& next dev -H 0.0.0.0 -p 3000 --experimental-https --experimental-https-key certificates/lan-key.pem --experimental-https-cert certificates/lan-cert.pem",
    "dev:https:customer": "set NEXT_PUBLIC_APP_VARIANT=customer&& next dev -H 0.0.0.0 -p 3000 --experimental-https",
    "dev:https:lan:customer": "set NEXT_PUBLIC_APP_VARIANT=customer&& next dev -H 0.0.0.0 -p 3000 --experimental-https --experimental-https-key certificates/lan-key.pem --experimental-https-cert certificates/lan-cert.pem",
    "build": "next build",
    "build:admin": "set NEXT_PUBLIC_APP_VARIANT=admin&& next build",
    "build:driver": "set NEXT_PUBLIC_APP_VARIANT=driver&& next build",
    "build:customer": "set NEXT_PUBLIC_APP_VARIANT=customer&& next build",
    "build:mobile": "next build",
    "vercel-build": "npx prisma generate && npx prisma migrate deploy && next build",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "cap:sync:android": "npx cap sync android",
    "cap:sync:android:driver": "set APP_VARIANT=driver&& npx cap sync android",
    "cap:sync:android:customer": "set APP_VARIANT=customer&& npx cap sync android",
    "cap:run:android": "npx cap run android",
    "cap:run:android:driver": "set APP_VARIANT=driver&& npx cap run android",
    "cap:run:android:customer": "set APP_VARIANT=customer&& npx cap run android",
    "cap:open:android": "npx cap open android",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:export": "node prisma/export-db.mjs",
    "storage:create-bucket": "node prisma/create-upload-bucket.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.1.0",
    "@capacitor/app": "^7.1.0",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/core": "^7.1.0",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@tanstack/react-query": "^5.82.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.2",
    "jose": "^6.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
